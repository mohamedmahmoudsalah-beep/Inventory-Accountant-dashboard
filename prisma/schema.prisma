generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
  VIEWER
}

enum DataSourceType {
  GOOGLE_SHEETS
  GOOGLE_DRIVE
  EXCEL
  CSV
}

enum WidgetType {
  BAR_CHART
  LINE_CHART
  PIE_CHART
  AREA_CHART
  TABLE
  KPI_CARD
  TEXT
  IMAGE
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(VIEWER)

  accounts      Account[]
  sessions      Session[]

  businessUnits BusinessUnitMember[]
  dashboards    Dashboard[]
  datasets      Dataset[]
  reports       Report[]
  auditLogs     AuditLog[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model BusinessUnit {
  id          String   @id @default(cuid())
  name        String
  nameAr      String?
  description String?
  color       String   @default("#F26522")
  isActive    Boolean  @default(true)

  members     BusinessUnitMember[]
  dashboards  Dashboard[]
  datasets    Dataset[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BusinessUnitMember {
  id             String   @id @default(cuid())
  userId         String
  businessUnitId String
  role           UserRole @default(EMPLOYEE)

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessUnit   BusinessUnit @relation(fields: [businessUnitId], references: [id], onDelete: Cascade)

  @@unique([userId, businessUnitId])
}

model Dataset {
  id             String         @id @default(cuid())
  name           String
  description    String?
  type           DataSourceType
  sourceConfig   String         // JSON string with connection details
  refreshInterval Int?          // minutes
  lastRefreshed  DateTime?
  dataSchema     String?        // JSON schema of the data
  rowCount       Int?
  isActive       Boolean        @default(true)

  businessUnitId String
  businessUnit   BusinessUnit   @relation(fields: [businessUnitId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User           @relation(fields: [createdById], references: [id], onDelete: Cascade)

  widgets        Widget[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Dashboard {
  id          String   @id @default(cuid())
  name        String
  description String?
  layout      String   @default("[]") // JSON array of widget positions
  isPublished Boolean  @default(false)
  isPublic    Boolean  @default(false)

  businessUnitId String
  businessUnit   BusinessUnit @relation(fields: [businessUnitId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User         @relation(fields: [createdById], references: [id], onDelete: Cascade)

  widgets     Widget[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Widget {
  id          String     @id @default(cuid())
  type        WidgetType
  title       String
  config      String     // JSON: datasetId, columns, filters, chart options
  position    String     // JSON: {x, y, w, h}

  dashboardId String
  dashboard   Dashboard  @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  datasetId   String?
  dataset     Dataset?   @relation(fields: [datasetId], references: [id], onDelete: SetNull)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Report {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   // dashboard, dataset, custom
  config      String   // JSON report configuration

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  userAgent String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
