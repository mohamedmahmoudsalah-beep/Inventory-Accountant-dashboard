# Copy this file to ".env" (same folder) and fill in your own values.
# Get these from Google Cloud Console — see README.md "Setting up real
# Google Drive access" for the exact steps. Never commit the real .env file
# (it's already in .gitignore).

VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_GOOGLE_API_KEY=your-api-key

# Get these from your Supabase project (Settings → API) — see README.md
# "Setting up shared storage" for the exact steps, including the SQL to
# create the required tables.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
